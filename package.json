{
  "name": "@digitalarkivet/mui-theme",
  "version": "5.0.3",
  "description": "MUI themes for Digitalarkivet applications",
  "private": false,
  "author": "Nasjonalarkivet",
  "main": "./dist/main.js",
  "module": "./dist/esm/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/esm/main.js",
      "require": "./dist/main.js",
      "default": "./dist/esm/main.js"
    },
    "./light": {
      "types": "./dist/themes/themeLight.d.ts",
      "import": "./dist/esm/themes/themeLight.js",
      "require": "./dist/themes/themeLight.js",
      "default": "./dist/esm/themes/themeLight.js"
    },
    "./dark": {
      "types": "./dist/themes/themeDark.d.ts",
      "import": "./dist/esm/themes/themeDark.js",
      "require": "./dist/themes/themeDark.js",
      "default": "./dist/esm/themes/themeDark.js"
    },
    "./combined": {
      "types": "./dist/themes/themeCombined.d.ts",
      "import": "./dist/esm/themes/themeCombined.js",
      "require": "./dist/themes/themeCombined.js",
      "default": "./dist/esm/themes/themeCombined.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/esm/components/*.js",
      "require": "./dist/components/*.js",
      "default": "./dist/esm/components/*.js"
    }
  },
  "license": "MIT",
  "homepage": "https://digitalarkivet.no",
  "keywords": [
    "mui",
    "digitalarkivet"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nasjonalarkivet/da-mui-theme.git"
  },
  "bugs": {
    "url": "https://github.com/nasjonalarkivet/da-mui-theme/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.dist.json && tsc -p tsconfig.esm.json && node scripts/write-esm-package-json.mjs",
    "prepare": "pnpm build",
    "gallery": "pnpm webpack serve",
    "clean": "rm -r dist/*",
    "ci": "pnpm install --frozen-lockfile",
    "self-up": "corepack use pnpm@latest",
    "outdated": "pnpm -r outdated",
    "up": "pnpm update --no-save # Update without changing package.json",
    "iup": "pnpm upgrade --interactive --latest",
    "rmnm": "rm -rf node_modules && rm -f pnpm-lock.yaml && rm -f package-lock.json",
    "depcheck": "pnpm dlx knip",
    "check-unmet-deps": "pnpm install --resolution-only"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@mui/x-date-pickers": "^9.0.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@types/node": "^24",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dayjs": "^1.11.19",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.6.5",
    "react-dom": "^19.2.3",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.3",
    "webpack": "^5.104.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "tailwind.css"
  ],
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
