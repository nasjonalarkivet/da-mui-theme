{
  "compilerOptions": {
    // https://mui.com/material-ui/guides/typescript/#minimum-configuration
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    //  End: minimum config
    "target": "es2020",
    "lib": [
      "es2020",
      "dom"
    ],
    "declaration": true, // https://www.totaltypescript.com/tsconfig-cheat-sheet#building-for-a-library
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "sourceMap": true, // https://www.totaltypescript.com/tsconfig-cheat-sheet#building-for-a-library-in-a-monorepo
    "resolvePackageJsonExports": false, // Needed for override of MUI theme module declarations with TypeScript 6+.
    "declarationMap": true,
    "rootDir": "src",
    "paths": {
      "@digitalarkivet/mui-theme/*": [
        "./src/*"
      ],
      "@gallery/*": [
        "./gallery/src/*"
      ],
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "gallery"
  ]
}